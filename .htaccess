# ICT Leerlijn — Apache configuration
# Place this file in the project root alongside index.html

# ── Correct MIME types for ES modules ────────────────────────────────────────
# Without this, browsers block type="module" scripts with a MIME error.
AddType application/javascript .js .mjs
AddType text/html              .html
AddType text/css               .css

# ── Allow cross-origin for module scripts (same-origin is fine, this is     ──
# ── only needed if you ever load from a CDN or subdomain)                    ──
# Header set Access-Control-Allow-Origin "*"

# ── Clean URLs (no .html extension) ────────────────────────────────────────
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ── Prevent directory listing ────────────────────────────────────────────────
Options -Indexes

# ── Cache static assets ──────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css              "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType text/html             "access plus 0 seconds"
</IfModule>
