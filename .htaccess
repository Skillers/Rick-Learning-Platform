# ICT Leerlijn — Apache configuration
# Place this file in the project root alongside index.html

# ── Correct MIME types for ES modules ────────────────────────────────────────
# Without this, browsers block type="module" scripts with a MIME error.
AddType application/javascript .js .mjs
AddType text/html              .html
AddType text/css               .css

# ── Allow cross-origin for module scripts (same-origin is fine, this is     ──
# ── only needed if you ever load from a CDN or subdomain)                    ──
# Header set Access-Control-Allow-Origin "*"

# ── Clean URLs (no .html extension) ────────────────────────────────────────
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ── Prevent directory listing ────────────────────────────────────────────────
Options -Indexes

# ── No stale code ────────────────────────────────────────────────────────────
# There's no build step, so caching HTML/JS/CSS just serves stale code after an
# edit (the root cause of "hard-refresh to see my fix"). Force revalidation on
# every request — cheap 304s on localhost. Media/uploads still cache normally.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|js|mjs|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html              "access plus 0 seconds"
  ExpiresByType text/css               "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType image/png              "access plus 1 week"
  ExpiresByType image/jpeg             "access plus 1 week"
  ExpiresByType image/svg+xml          "access plus 1 week"
</IfModule>
